<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand Palette: Glassy Midnight v2 -->
    <Color x:Key="Primary">#6366F1</Color> <!-- Electric Indigo -->
    <Color x:Key="PrimaryDark">#4F46E5</Color>
    <Color x:Key="PrimaryLight">#818CF8</Color>
    
    <Color x:Key="Secondary">#F43F5E</Color> <!-- Rose/Pink for contrast -->
    <Color x:Key="Accent">#10B981</Color> <!-- Emerald for success -->

    <!-- Semantic Colors -->
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Error">#EF4444</Color>
    <Color x:Key="Warning">#F59E0B</Color>

    <!-- Deep Midnight Palette -->
    <Color x:Key="BgDark">#0F172A</Color>
    <Color x:Key="BgDarker">#020617</Color>
    <Color x:Key="SurfaceDark">#1E293B</Color>
    <Color x:Key="SurfaceDarkGlass">#334155</Color>
    
    <Color x:Key="TextPrimary">#F8FAFC</Color>
    <Color x:Key="TextSecondary">#94A3B8</Color>
    <Color x:Key="BorderDark">#334155</Color>

    <!-- Light Mode (Minimalistic support) -->
    <Color x:Key="BgLight">#F1F5F9</Color>
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="TextPrimaryLight">#0F172A</Color>
    <Color x:Key="TextSecondaryLight">#64748B</Color>
    <Color x:Key="BorderLight">#E2E8F0</Color>

    <!-- Legacy / System Compatibility -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#E2E8F0</Color>
    <Color x:Key="Gray300">#CBD5E1</Color>
    <Color x:Key="Gray500">#64748B</Color>
    <Color x:Key="Gray900">#0F172A</Color>

    <!-- Theme-resolved dynamic colors (overridden at runtime by ThemeManager) -->
    <Color x:Key="CardBackground">#1E293B</Color>
    <Color x:Key="CardBorder">#334155</Color>
    <Color x:Key="TextPrimaryColor">#F8FAFC</Color>
    <Color x:Key="TextSecondaryColor">#94A3B8</Color>
    <Color x:Key="PageBackground">#0F172A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDark}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    
    <!-- Glassmorphism Brushes -->
    <LinearGradientBrush x:Key="GlassBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#26FFFFFF" Offset="0.0" />
        <GradientStop Color="#0DFFFFFF" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PageGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0F172A" Offset="0.0" />
        <GradientStop Color="#020617" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PageGradientLight" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F8FAFC" Offset="0.0" />
        <GradientStop Color="#E2E8F0" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PageGradientDark" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0F172A" Offset="0.0" />
        <GradientStop Color="#020617" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#6366F1" Offset="0.0" />
        <GradientStop Color="#8B5CF6" Offset="1.0" />
    </LinearGradientBrush>

</ResourceDictionary>