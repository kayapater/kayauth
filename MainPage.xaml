<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AuthApp.ViewModels"
             xmlns:models="clr-namespace:AuthApp.Models"
             xmlns:helpers="clr-namespace:AuthApp.Helpers"
             xmlns:controls="clr-namespace:AuthApp.Controls"
             xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="AuthApp.MainPage"
             x:DataType="viewmodels:MainViewModel"
             x:Name="thisPage"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <helpers:ProgressToSecondsConverter x:Key="ProgressToSecondsConverter" />
        <helpers:ProgressToColorConverter x:Key="ProgressToColorConverter" />
        <mct:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <Grid Background="{DynamicResource PageGradient}">
        <AbsoluteLayout InputTransparent="True">
            <Ellipse Fill="{DynamicResource PrimaryBrush}" Opacity="0.12" WidthRequest="300" HeightRequest="300"
                      AbsoluteLayout.LayoutBounds="0.1,-0.05,300,300" AbsoluteLayout.LayoutFlags="PositionProportional" />
            <Ellipse Fill="{DynamicResource PrimaryDarkBrush}" Opacity="0.08" WidthRequest="250" HeightRequest="250"
                      AbsoluteLayout.LayoutBounds="0.95,0.15,250,250" AbsoluteLayout.LayoutFlags="PositionProportional" />
        </AbsoluteLayout>

        <Grid RowDefinitions="Auto, Auto, *" RowSpacing="20" Padding="24,24,24,0" MaximumWidthRequest="720" HorizontalOptions="Center">
            <!-- Header -->
            <Grid x:Name="HeaderSection" Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,8,0,4" Opacity="0" TranslationY="12">
                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                    <Label Text="Kayauth" Style="{StaticResource DisplayLabel}" />
                    <Label Text="Güvenli kodlar, tek ritim." Style="{StaticResource SubtitleLabel}" Opacity="0.8" />
                </VerticalStackLayout>
            
                <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                    <!-- Toggle View Mode Button -->
                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 22" WidthRequest="44" HeightRequest="44"
                            BackgroundColor="{DynamicResource CardBackground}">
                        <Border.Behaviors>
                            <mct:TouchBehavior PressedScale="0.92" PressedOpacity="0.7" Command="{Binding ToggleViewModeCommand}" />
                        </Border.Behaviors>
                        <Grid>
                            <Path Data="M4,11h5V4H4v7Zm0,9h5v-7H4v7Zm7,0h5v-7h-5v7Zm7,0h5v-7h-5v7Zm-7,-9h5V4h-5v7Zm7,-7v7h5V4h-5Z" Fill="{DynamicResource Primary}" Aspect="Uniform" WidthRequest="18" HeightRequest="18" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding IsCompactMode}" />
                            <Path Data="M3,18h18v-2H3v2Zm0,-5h18v-2H3v2Zm0,-7v2h18V6H3Z" Fill="{DynamicResource Primary}" Aspect="Uniform" WidthRequest="18" HeightRequest="18" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding IsCompactMode, Converter={StaticResource InvertedBoolConverter}}" />
                        </Grid>
                    </Border>

                    <!-- Settings Button -->
                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 22" WidthRequest="44" HeightRequest="44"
                            BackgroundColor="{DynamicResource CardBackground}">
                        <Border.Behaviors>
                            <mct:TouchBehavior PressedScale="0.92" PressedOpacity="0.7" Command="{Binding NavigateToSettingsCommand}" />
                        </Border.Behaviors>
                        <Path Data="M19.43,12.98c0.04,-0.32 0.07,-0.64 0.07,-0.98c0,-0.34 -0.03,-0.66 -0.07,-0.98l2.11,-1.65c0.19,-0.15 0.24,-0.42 0.12,-0.64l-2,-3.46c-0.12,-0.22 -0.39,-0.3 -0.61,-0.22l-2.49,1c-0.52,-0.4 -1.08,-0.73 -1.69,-0.98l-0.37,-2.65c-0.04,-0.24 -0.25,-0.42 -0.5,-0.42h-4c-0.25,0 -0.46,0.18 -0.5,0.42l-0.37,2.65c-0.61,0.25 -1.17,0.59 -1.69,0.98l-2.49,-1c-0.22,-0.09 -0.49,0 -0.61,0.22l-2,3.46c-0.13,0.22 -0.07,0.49 0.12,0.64l2.11,1.65c-0.04,0.32 -0.07,0.65 -0.07,0.98c0,0.33 0.03,0.66 0.07,0.98l-2.11,1.65c-0.19,0.15 -0.24,0.42 -0.12,0.64l2,3.46c0.12,0.22 0.39,0.3 0.61,0.22l2.49,-1c0.52,0.4 1.08,0.73 1.69,0.98l0.37,2.65c0.04,0.24 0.25,0.42 0.5,0.42h4c0.25,0 0.46,-0.18 0.5,-0.42l0.37,-2.65c0.61,-0.25 1.17,-0.59 1.69,-0.98l2.49,1c0.22,0.09 0.49,0 0.61,-0.22l2,-3.46c0.12,-0.22 0.07,-0.49 -0.12,-0.64l-2.11,-1.65Z M12,15.5c-1.93,0 -3.5,-1.57 -3.5,-3.5c0,-1.93 1.57,-3.5 3.5,-3.5c1.93,0 3.5,1.57 3.5,3.5c0,1.93 -1.57,3.5 -3.5,3.5Z" Fill="{DynamicResource TextSecondaryColor}" Aspect="Uniform" WidthRequest="18" HeightRequest="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <!-- Add Button -->
                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 22" WidthRequest="44" HeightRequest="44"
                            Background="{DynamicResource AccentGradient}">
                        <Border.Behaviors>
                            <mct:TouchBehavior PressedScale="0.92" PressedOpacity="0.8" Command="{Binding NavigateToAddAccountCommand}" />
                        </Border.Behaviors>
                        <Path Data="M19,13h-6v6h-2v-6H5v-2h6V5h2v6h6v2Z" Fill="White" Aspect="Uniform" WidthRequest="18" HeightRequest="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </HorizontalStackLayout>
            </Grid>

            <!-- Search Box -->
            <Border x:Name="SearchSection" Grid.Row="1" Style="{StaticResource GlassCard}" Padding="16,4" Margin="0,0,0,4" Opacity="0" TranslationY="12" StrokeShape="RoundRectangle 18">
                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                    <Path Data="M15.5,14h-0.79l-0.28,-0.27C15.41,12.59 16,11.11 16,9.5 16,5.91 13.09,3 9.5,3S3,5.91 3,9.5 5.91,16 9.5,16c1.61,0 3.09,-0.59 4.23,-1.57l0.27,0.28v0.79l5,4.99L20.49,19l-4.99,-5Z M9.5,14C7.01,14 5,11.99 5,9.5S7.01,5 9.5,5 14,7.01 14,9.5 11.99,14 9.5,14Z" Fill="{DynamicResource TextSecondaryColor}" Aspect="Uniform" WidthRequest="18" HeightRequest="18" VerticalOptions="Center" Opacity="0.5" />
                    <Entry Grid.Column="1" Text="{Binding SearchText}" Placeholder="Hesap ara..." VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Accounts List -->
            <Grid x:Name="ListSection" Grid.Row="2" RowDefinitions="Auto, *" RowSpacing="14" Opacity="0" TranslationY="12">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                    <Label Text="Hesaplar" Style="{StaticResource SectionLabel}" />
                    <Border Grid.Column="1" Padding="12,4" StrokeThickness="0" StrokeShape="RoundRectangle 12"
                            BackgroundColor="{DynamicResource CardBackground}">
                        <Label Text="{Binding FilteredAccounts.Count, StringFormat='{}{0} hesap'}" Style="{StaticResource EyebrowLabel}" />
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <CollectionView x:Name="AccountsList" ItemsSource="{Binding FilteredAccounts}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:AuthenticatorAccount">
                                <ContentView>
                                    <Grid>
                                        <!-- CARD VIEW -->
                                        <Border Style="{StaticResource GlassCard}"
                                                IsVisible="{Binding BindingContext.IsCompactMode, Source={x:Reference thisPage}, Converter={StaticResource InvertedBoolConverter}}"
                                                Opacity="0" TranslationY="12" Loaded="OnAccountItemLoaded">
                                            <Grid ColumnDefinitions="58, *, 70" ColumnSpacing="16">
                                                <Border Grid.Column="0" Padding="0" WidthRequest="56" HeightRequest="56"
                                                        StrokeShape="RoundRectangle 16" StrokeThickness="1"
                                                        Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                                                    <Image Source="{Binding IconUrl}" Aspect="AspectFit" Margin="11" />
                                                </Border>

                                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                                    <Label Text="{Binding Issuer}" Style="{StaticResource SectionLabel}" LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding AccountName}" Style="{StaticResource SubtitleLabel}" LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding FormattedCode}" Style="{StaticResource CodeLabel}" Margin="0,4,0,0">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding BindingContext.CopyToClipboardCommand, Source={x:Reference thisPage}}" CommandParameter="{Binding CurrentCode}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                </VerticalStackLayout>
                                            
                                                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                                                    <Grid WidthRequest="44" HeightRequest="44">
                                                        <controls:CircularProgressBar Progress="{Binding RemainingProgress}"
                                                                                      ProgressColor="{Binding RemainingProgress, Converter={StaticResource ProgressToColorConverter}}"
                                                                                      WidthRequest="44" HeightRequest="44" />
                                                        <Label Text="{Binding RemainingProgress, Converter={StaticResource ProgressToSecondsConverter}}" 
                                                               Style="{StaticResource EyebrowLabel}" HorizontalOptions="Center" VerticalOptions="Center" FontSize="10" />
                                                    </Grid>
                                                     <Border StrokeThickness="0" StrokeShape="RoundRectangle 16" WidthRequest="32" HeightRequest="32" BackgroundColor="#26EF4444">
                                                         <Border.GestureRecognizers>
                                                             <TapGestureRecognizer Tapped="OnDeleteAccountTapped" CommandParameter="{Binding .}" />
                                                         </Border.GestureRecognizers>
                                                         <Path Data="M6,19c0,1.1 0.9,2 2,2h8c1.1,0 2,-0.9 2,-2V7H6v12Z M19,4h-3.5l-1,-1h-5l-1,1H5v2h14V4Z" Fill="{DynamicResource Error}" Aspect="Uniform" WidthRequest="13" HeightRequest="13" HorizontalOptions="Center" VerticalOptions="Center" />
                                                     </Border>
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>

                                        <!-- COMPACT VIEW -->
                                        <Border Style="{StaticResource GlassCard}" Padding="14,12"
                                                IsVisible="{Binding BindingContext.IsCompactMode, Source={x:Reference thisPage}}">
                                            <Grid ColumnDefinitions="36, *, Auto, Auto" ColumnSpacing="14" VerticalOptions="Center">
                                                <Image Grid.Column="0" Source="{Binding IconUrl}" WidthRequest="28" HeightRequest="28" />
                                            
                                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                                    <Label Text="{Binding Issuer}" FontAttributes="Bold" FontSize="15" LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding AccountName}" Style="{StaticResource SubtitleLabel}" FontSize="12" LineBreakMode="TailTruncation" />
                                                </VerticalStackLayout>

                                                <Label Grid.Column="2" Text="{Binding FormattedCode}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Primary}" FontFamily="Monospace" VerticalOptions="Center" Margin="0,0,4,0">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding BindingContext.CopyToClipboardCommand, Source={x:Reference thisPage}}" CommandParameter="{Binding CurrentCode}" />
                                                    </Label.GestureRecognizers>
                                                </Label>

                                                <Grid Grid.Column="3" WidthRequest="26" HeightRequest="26" VerticalOptions="Center">
                                                    <controls:CircularProgressBar Progress="{Binding RemainingProgress}"
                                                                                  ProgressColor="{Binding RemainingProgress, Converter={StaticResource ProgressToColorConverter}}"
                                                                                  WidthRequest="26" HeightRequest="26" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </ContentView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Manual Empty State View (More reliable than EmptyView) -->
                    <Border Style="{StaticResource GlassCard}" VerticalOptions="Start" Margin="0,20"
                            IsVisible="{Binding IsEmptyStateVisible}">
                        <VerticalStackLayout Spacing="12" HorizontalOptions="Center" Padding="0,20">
                            <Grid HorizontalOptions="Center" WidthRequest="64" HeightRequest="64" Margin="0,10">
                                <Ellipse Fill="{DynamicResource Primary}" Opacity="0.12" />
                                <Path Data="M12,1L3,5v6c0,5.55 3.84,10.74 9,12 5.16,-1.26 9,-6.45 9,-12V5l-9,-4Z M12,11.99h7c-0.53,4.12 -3.28,7.79 -7,8.94V12H5V6.3l7,-3.11v8.8Z" Fill="{DynamicResource Primary}" Aspect="Uniform" WidthRequest="32" HeightRequest="32" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Grid>
                            <Label Text="Henüz hesap yok." Style="{StaticResource SectionLabel}" HorizontalTextAlignment="Center" />
                            <Label Text="İlk hesabını ekleyerek başla." Style="{StaticResource SubtitleLabel}" HorizontalTextAlignment="Center" />
                            <Button Text="Hesap ekle" Command="{Binding NavigateToAddAccountCommand}" Margin="0,10,0,0" WidthRequest="160">
                                <Button.Behaviors>
                                    <mct:TouchBehavior PressedScale="0.96" PressedOpacity="0.8" />
                                </Button.Behaviors>
                            </Button>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Toast -->
                    <Border x:Name="ToastFrame" VerticalOptions="End" HorizontalOptions="Center" Margin="0,0,0,40" Padding="18,12"
                            StrokeThickness="0" StrokeShape="RoundRectangle 20"
                            Background="{StaticResource AccentGradient}"
                            IsVisible="{Binding IsCopyMessageVisible}" ZIndex="10">
                        <Label Text="Kod Kopyalandı" TextColor="White" FontSize="13" FontAttributes="Bold" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
